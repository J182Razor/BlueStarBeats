  "libraries": {
    "audioEngine.ts": {
      "purpose": "Web Audio API engine for generating binaural beats and isochronic tones",
      "class": "AudioEngine",
      "keyMethods": {
        "initialize()": "Creates AudioContext and sets up audio nodes with iOS support",
        "start()": "Starts audio generation based on current mode",
        "stop()": "Stops audio and cleans up nodes",
        "updateSettings()": "Updates audio parameters in real-time",
        "setupBinauralBeats()": "Configures stereo oscillators for binaural beats",
        "setupIsochronicTones()": "Configures LFO-modulated gain for isochronic tones",
        "getAnalyserData()": "Returns time-domain data for visualization",
        "getFrequencyData()": "Returns frequency-domain data",
        "cleanup()": "Disconnects and stops all audio nodes",
        "scheduleFrequencyChange()": "Web Audio API scheduling for frequency changes",
        "scheduleBeatFrequencyChange()": "Web Audio API scheduling for beat frequency",
        "clearSchedule()": "Clears all scheduled events"
      },
      "audioNodes": {
        "masterGain": "Main volume control",
        "leftOscillator/rightOscillator": "Stereo oscillators for binaural beats",
        "isoOscillator": "Main oscillator for isochronic tones",
        "isoLFO": "Low-frequency oscillator for isochronic modulation",
        "compressor": "Dynamics compressor to prevent clipping",
        "lowPassFilter": "Anti-aliasing filter (18kHz)",
        "highPassFilter": "DC and rumble removal (20Hz)",
        "analyser": "FFT analyser for visualization"
      },
      "features": {
        "binauralBeats": {
          "implementation": "Two oscillators with frequency difference",
          "stereoPanning": "StereoPannerNode with PannerNode fallback",
          "gainMultipliers": "Waveform-specific gain to prevent distortion"
        },
        "isochronicTones": {
          "implementation": "LFO-modulated gain using requestAnimationFrame",
          "modulationRange": "Base gain (0.5) to min gain (0.15)",
          "updateMethod": "requestAnimationFrame loop calculating LFO from AudioContext.currentTime",
          "cleanup": "Proper cancellation of animation frame loop"
        },
        "iosSupport": {
          "iosAudioManager": "Integration with IOSAudioManager",
          "interruptionHandling": "Phone calls, Siri, background/foreground",
          "statePreservation": "Maintains state during interruptions"
        },
        "scheduling": {
          "webAudioScheduling": "Precise timing using Web Audio API",
          "scheduledEvents": "Map-based event tracking",
          "frequencyRamping": "Smooth frequency transitions"
        }
      },
      "optimizations": [
        "No hardcoded sampleRate (allows system default)",
        "Fallback to PannerNode if StereoPannerNode unavailable",
        "Smooth frequency transitions (setTargetAtTime)",
        "Waveform-specific gain multipliers to prevent clipping",
        "Audio context state monitoring and auto-resume",
        "Proper cleanup of animation loops"
      ],
      "linesOfCode": "~665"
