  "keyAlgorithms": {
    "audioGeneration": {
      "binauralBeats": {
        "description": "Two oscillators with frequency difference create perceived beat",
        "leftFrequency": "carrierFrequency",
        "rightFrequency": "carrierFrequency + beatFrequency",
        "stereoPanning": "StereoPannerNode with PannerNode fallback"
      },
      "isochronicTones": {
        "description": "LFO modulates gain to create pulsing effect",
        "modulationFormula": "gain = minGain + (normalizedLFO * modulationRange)",
        "lfoCalculation": "Math.sin(time * beatFrequency * 2 * Math.PI)",
        "updateMethod": "requestAnimationFrame loop"
      },
      "frequencyRamping": {
        "description": "Gradual frequency transition over time",
        "method": "Web Audio API scheduling (setValueAtTime)",
        "precision": "Sample-accurate timing",
        "replaces": "setInterval (drift-prone)"
      }
    },
