    "version": "0.0.0",
    "type": "module",
    "repository": "https://github.com/J182Razor/BlueStarBeats.git",
    "license": "Private",
    "platforms": ["Web", "iOS (Capacitor)"]
  },
  "technologyStack": {
    "framework": "React 18.2.0 with TypeScript 5.2.2",
    "buildTool": "Vite 5.2.0",
    "styling": "Tailwind CSS 3.4.3",
    "audioEngine": "Web Audio API (native browser API)",
    "mobileFramework": "Capacitor 7.4.4 (iOS support)",
    "stateManagement": "React Hooks (useState, useEffect, useCallback, useMemo, useRef)",
    "language": "TypeScript (strict mode enabled)",
    "bundler": "Vite with ES modules"
  },
  "projectStructure": {
    "rootFiles": [
      "package.json",
      "tsconfig.json",
      "vite.config.ts",
      "capacitor.config.ts",
      "tailwind.config.js",
      "postcss.config.js",
      "index.html",
      "README.md"
    ],
    "directories": {
      "src/": {
        "description": "Main source code",
        "subdirectories": {
          "components/": "13 React UI components",
          "lib/": "10 core business logic and utility files",
          "styles/": "CSS design system and custom styles"
        }
      },
      "ios/": {
        "description": "iOS native app configuration (Capacitor)",
        "keyFiles": [
          "App/App/AppDelegate.swift",
          "App/App/Info.plist",
          "App/Podfile"
        ]
      },
      "docs/": {
        "description": "Documentation files",
        "files": [
          "IOS_SETUP.md",
          "TROUBLESHOOTING.md",
          "USAGE.md",
          "BACKGROUND_AUDIO.md",
          "UI_UX_UPGRADE_SUMMARY.md"
        ]
      },
      "scripts/": {
        "description": "Build and utility scripts",
        "files": [
          "build-ios.sh",
          "clean-and-rebuild.sh",
          "fix-pods-script.sh",
          "fix-ios-audio.sh",
          "diagnose-build-error.sh"
        ]
      },
      "public/": "Static assets (logos, images)",
      "dist/": "Production build output"
    }
  },
  "components": {
